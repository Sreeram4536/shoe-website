<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="css/bootstrap.min.css" type="text/css" />
    <link rel="stylesheet" href="/css/register.css">
    <style>
      /* Password wrapper — scoped only to this field */
      .password-wrapper {
        position: relative;
        display: flex;
        align-items: center;
      }
      .password-wrapper input {
        width: 100%;
        padding-right: 44px;
      }
      .eye-toggle {
        position: absolute;
        right: 10px;
        background: none;
        border: none;
        padding: 4px;
        cursor: pointer;
        color: #888;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 4px;
        transition: color 0.2s ease;
        outline: none;
      }
      .eye-toggle:hover {
        color: #333;
      }
      .eye-toggle:focus-visible {
        outline: 2px solid #00b4d8;
        outline-offset: 2px;
      }
      .eye-toggle svg {
        width: 20px;
        height: 20px;
        transition: opacity 0.15s ease, transform 0.15s ease;
      }
      .icon-eye-off {
        position: absolute;
      }
      .eye-toggle.is-visible .icon-eye      { opacity: 1; transform: scale(1); }
      .eye-toggle.is-visible .icon-eye-off  { opacity: 0; transform: scale(0.8); }
      .eye-toggle:not(.is-visible) .icon-eye     { opacity: 0; transform: scale(0.8); }
      .eye-toggle:not(.is-visible) .icon-eye-off { opacity: 1; transform: scale(1); }
    </style>
</head>
<body>
    <!-- <div id="particles-js" class="snow"></div> -->

    <main>
       <div class="left-side">
        
       </div>
      
      <div class="right-side">
        <h3>Login</h3><br><br>
        <form  id="loginform" method="post" action="./login">
        
          <div class="btn-group">
            <a href="/auth/google" class="btn">
              <img class="logo" src="https://github.com/ecemgo/mini-samples-great-tricks/assets/13468728/d1c98974-c62d-4071-8bd2-ab859fc5f4e9" alt="" />
              <span>Sign in with Google</span>
            </a>
            
          </div>
          <br>

        <label for="email">Email address</label>
        <input id="email" type="text" placeholder="email address" name="email" required>
        <div id="error1" class="error-message"></div>
        <label for="password">Password</label>
        <div class="password-wrapper">
          <input
            id="password"
            type="password"
            placeholder="Enter Password"
            name="password"
            required />
          <button
            type="button"
            class="eye-toggle"
            id="togglePassword"
            aria-label="Show password"
            title="Show password"
          >
            <!-- Eye open -->
            <svg class="icon-eye" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7z"/>
              <circle cx="12" cy="12" r="3"/>
            </svg>
            <!-- Eye off -->
            <svg class="icon-eye-off" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/>
              <path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/>
              <line x1="1" y1="1" x2="23" y2="23"/>
            </svg>
          </button>
        </div>
          <div id="error2" class="error-message"></div>
          <%if(locals.message && message.length>0){%>
            <div class="alert alert-danger text-center">
              <%=message%>
            </div>
          <%}%>

        <button type="submit" class="login-btn">Login</button>
         <div class="links">
          <a href="/user/forgot-password">Forgot password?</a>
          <a href="./signup">Do not have an account?</a>
        </div> 
      </form>
      </div>
    </main>

   

    <script>
      document.getElementById("togglePassword").addEventListener("click", function () {
        const passwordField = document.getElementById("password");
        const isPassword = passwordField.type === "password";
        passwordField.type = isPassword ? "text" : "password";
        this.classList.toggle("is-visible", isPassword);
        this.setAttribute("aria-label", isPassword ? "Hide password" : "Show password");
        this.setAttribute("title", isPassword ? "Hide password" : "Show password");
      });
    </script>

  </body>
</html>